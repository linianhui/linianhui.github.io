<?xml version="1.0" encoding="utf-8" standalone="yes"?><rss version="2.0" xmlns:atom="http://www.w3.org/2005/Atom"><channel><title>Vlmcsd on Timetombs</title><link>https://linianhui.github.io/tag/vlmcsd/</link><description>Recent content in Vlmcsd on Timetombs</description><generator>Hugo</generator><language>en</language><lastBuildDate>Sun, 10 Nov 2024 12:35:09 +0800</lastBuildDate><atom:link href="https://linianhui.github.io/tag/vlmcsd/index.xml" rel="self" type="application/rss+xml"/><item><title>[工具] vlmcsd</title><link>https://linianhui.github.io/tool/vlmcsd/</link><pubDate>Sun, 10 Nov 2024 12:00:08 +0800</pubDate><guid>https://linianhui.github.io/tool/vlmcsd/</guid><description>&lt;h1 id="windows"&gt;
&lt;i id="locator-windows" class="header-locator"&gt;&lt;/i&gt;
&lt;a href="#windows" class="article-h-a"&gt;Windows&lt;/a&gt;
&lt;/h1&gt;
&lt;p&gt;&lt;a href="https://github.com/Wind4/vlmcsd"

 target="_blank" rel="noopener norefferrer"&gt;https://github.com/Wind4/vlmcsd&lt;/a&gt;&lt;/p&gt;
&lt;div class="highlight"&gt;&lt;pre tabindex="0" style="background-color:#fff;-moz-tab-size:4;-o-tab-size:4;tab-size:4;-webkit-text-size-adjust:none;"&gt;&lt;code class="language-sh" data-lang="sh"&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;&lt;span style="color:#008000"&gt;# 服务端 -s 注册为windows服务 -l 日志&lt;/span&gt;
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;vlmcsd-Windows-x64.exe -s -l c:&lt;span style="color:#a31515"&gt;\_&lt;/span&gt;vlmcsd&lt;span style="color:#a31515"&gt;\s&lt;/span&gt;erver.log
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;&lt;span style="color:#008000"&gt;# 客户端-查看支持的版本&lt;/span&gt;
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;vlmcs-Windows-x64.exe -x
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;&lt;span style="color:#008000"&gt;# 开放端口&lt;/span&gt;
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;netsh advfirewall firewall add rule name=vlmcsd1688 dir=in action=allow protocol=TCP localport=1688
&lt;/span&gt;&lt;/span&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;h1 id="docker"&gt;
&lt;i id="locator-docker" class="header-locator"&gt;&lt;/i&gt;
&lt;a href="#docker" class="article-h-a"&gt;Docker&lt;/a&gt;
&lt;/h1&gt;
&lt;div class="highlight"&gt;&lt;pre tabindex="0" style="background-color:#fff;-moz-tab-size:4;-o-tab-size:4;tab-size:4;-webkit-text-size-adjust:none;"&gt;&lt;code class="language-sh" data-lang="sh"&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;docker run -d -p 1688:1688 --restart=always --name vlmcsd ghcr.io/linianhui/vlmcsd:1113-2020-03-28
&lt;/span&gt;&lt;/span&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;h1 id="openwrt"&gt;
