&lt;h1 id="hdd"&gt;
&lt;i id="locator-hdd" class="header-locator"&gt;&lt;/i&gt;
&lt;a href="#hdd" class="article-h-a"&gt;机械硬盘&lt;/a&gt;
&lt;/h1&gt;
&lt;div id="hddList" class="inner-html"&gt;
 &lt;el-table :data="hdds" :default-sort="{prop: 'price'}" highlight-current-row="true"&gt;
 &lt;el-table-column prop="capacityBytes" label="容量" sortable="true" min-width="70"&gt;
 &lt;template slot-scope="scope"&gt;
 &lt;span :title="scope.row.actualCapacityTB+'\n'+scope.row.actualCapacityGB"&gt;
 {{scope.row.capacity}}
 &lt;/span&gt;
 &lt;/template&gt;
 &lt;/el-table-column&gt;
 &lt;el-table-column prop="brand" label="品牌" sortable="true" min-width="80"&gt;
 &lt;template slot-scope="scope"&gt;
 &lt;a v-if="scope.row.brandUrl" :href="scope.row.brandUrl" target="_blank"&gt;{{scope.row.brand}}&lt;/a&gt;
 &lt;span v-else&gt;{{scope.row.brand}}&lt;/span&gt;
 &lt;/template&gt;
 &lt;/el-table-column&gt;
 &lt;el-table-column prop="series" label="系列" sortable="true" min-width="150"&gt;
 &lt;template slot-scope="scope"&gt;
 &lt;a v-if="scope.row.seriesUrl" :href="scope.row.seriesUrl" target="_blank"&gt;{{scope.row.series}}&lt;/a&gt;
 &lt;span v-else&gt;{{scope.row.series}}&lt;/span&gt;
 &lt;/template&gt;
 &lt;/el-table-column&gt;
 &lt;el-table-column prop="model" label="型号" sortable="true" min-width="150"&gt;
 &lt;template slot-scope="scope"&gt;
 &lt;a v-if="scope.row.datasheetUrl" :href="scope.row.datasheetUrl" target="_blank"&gt;{{scope.row.model}}&lt;/a&gt;
 &lt;span v-else&gt;{{scope.row.model}}&lt;/span&gt;
 &lt;/template&gt;
 &lt;/el-table-column&gt;
 &lt;el-table-column prop="recording" label="记录" sortable="true" min-width="60"&gt;
 &lt;/el-table-column&gt;
 &lt;el-table-column prop="cache" label="缓存" sortable="true" min-width="70"&gt;
 &lt;/el-table-column&gt;
 &lt;el-table-column prop="rpm" label="转速" sortable="true" min-width="70"&gt;
 &lt;/el-table-column&gt;
 &lt;el-table-column prop="price" label="价格" sortable="true" min-width="120"&gt;
 &lt;template slot-scope="scope"&gt;
 {{scope.row.price}} &lt;sub style="color: #999;font-size: 10px;font-style: italic;"&gt;{{scope.row.priceDate}}&lt;/span&gt;
 &lt;/template&gt;
 &lt;/el-table-column&gt;
 &lt;el-table-column prop="model" label="电商"&gt;
 &lt;template slot-scope="scope"&gt;
 &lt;a :href="scope.row.shopJDUrl" target="_blank"&gt;京东&lt;/a&gt;
 &lt;a :href="scope.row.shopTBUrl" target="_blank"&gt;淘宝&lt;/a&gt;
 &lt;/template&gt;
 &lt;/el-table-column&gt;
 &lt;/el-table&gt;
