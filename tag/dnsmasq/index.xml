<?xml version="1.0" encoding="utf-8" standalone="yes"?><rss version="2.0" xmlns:atom="http://www.w3.org/2005/Atom"><channel><title>Dnsmasq on Timetombs</title><link>https://linianhui.github.io/tag/dnsmasq/</link><description>Recent content in Dnsmasq on Timetombs</description><generator>Hugo</generator><language>en</language><lastBuildDate>Sat, 26 Nov 2022 21:13:14 +0800</lastBuildDate><atom:link href="https://linianhui.github.io/tag/dnsmasq/index.xml" rel="self" type="application/rss+xml"/><item><title>[计算机网络] DNS(Domain Name System)</title><link>https://linianhui.github.io/computer-networking/dns/</link><pubDate>Sat, 01 Jan 2022 13:54:00 +0800</pubDate><guid>https://linianhui.github.io/computer-networking/dns/</guid><description>&lt;h1 id="dnsmasq"&gt;
&lt;i id="locator-dnsmasq" class="header-locator"&gt;&lt;/i&gt;
&lt;a href="#dnsmasq" class="article-h-a"&gt;dnsmasq&lt;/a&gt;
&lt;/h1&gt;
&lt;p&gt;&lt;a href="https://thekelleys.org.uk/dnsmasq/docs/dnsmasq-man.html"

 target="_blank" rel="noopener norefferrer"&gt;https://thekelleys.org.uk/dnsmasq/docs/dnsmasq-man.html&lt;/a&gt;&lt;/p&gt;
&lt;p&gt;&lt;div class="highlight-file highlight-file_opened" id="hf-4ac609d99afb8c6615d4989bf5342a0e"&gt;
 &lt;div class="highlight-file-header"&gt;
 &lt;a class="fa fa-plus highlight-file-switch" onclick="blog.toggleClassName('hf-4ac609d99afb8c6615d4989bf5342a0e','highlight-file_opened')"&gt;/etc/dnsmasq.conf&lt;/a&gt;&lt;a class="fa fa-download highlight-file-download" target="_blank" href="https://linianhui.github.io/computer-networking/dns/dnsmasq.conf" title="下载 /etc/dnsmasq.conf" download&gt;&lt;/a&gt;
 &lt;a class="fa fa-github" target="_blank" href="https://github.com/linianhui/blog/blob/main/src/computer-networking/dns/dnsmasq.conf" title="源码 /etc/dnsmasq.conf"&gt;&lt;/a&gt;&lt;/div&gt;
 &lt;div class="highlight-file-content"&gt;&lt;div class="highlight"&gt;&lt;pre tabindex="0" style="background-color:#fff;-moz-tab-size:4;-o-tab-size:4;tab-size:4;-webkit-text-size-adjust:none;"&gt;&lt;code class="language-ini" data-lang="ini"&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;&lt;span style="color:#008000"&gt;# /etc/dnsmasq.conf&lt;/span&gt;
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;&lt;span style="color:#008000"&gt;# https://thekelleys.org.uk/dnsmasq/docs/dnsmasq-man.html&lt;/span&gt;
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;&lt;span style="color:#008000"&gt;# 文件变化自动加载，无需重启&lt;/span&gt;
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;log-queries=&lt;span style="color:#a31515"&gt;extra&lt;/span&gt;
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;log-dhcp
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;log-facility=&lt;span style="color:#a31515"&gt;/log/dnsmasq.log&lt;/span&gt;
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;&lt;span style="color:#008000"&gt;# DNS - 上游DNS服务器配置文件&lt;/span&gt;
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;strict-order
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;resolv-file=&lt;span style="color:#a31515"&gt;/etc/dnsmasq.dns.upstream.conf&lt;/span&gt;
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;&lt;span style="color:#008000"&gt;# DNS - 本地DNS配置文件&lt;/span&gt;
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;addn-hosts=&lt;span style="color:#a31515"&gt;/etc/dnsmasq.dns.hosts&lt;/span&gt;
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;&lt;span style="color:#008000"&gt;# 防止将没有域部分的本地名称转发到上游DNS服务器&lt;/span&gt;
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;domain-needed
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;&lt;span style="color:#008000"&gt;# 防止将DNS反向查找查询转发到上游DNS服务器&lt;/span&gt;
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;bogus-priv
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;&lt;span style="color:#008000"&gt;# DHCP -&lt;/span&gt;
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;dhcp-option=&lt;span style="color:#a31515"&gt;option:router,192.168.2.1&lt;/span&gt;
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;dhcp-option=&lt;span style="color:#a31515"&gt;option:netmask,255.255.255.0&lt;/span&gt;
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;&lt;span style="color:#008000"&gt;# DHCP - DHCP静态分配&lt;/span&gt;
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;read-ethers
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;dhcp-hostsfile=&lt;span style="color:#a31515"&gt;/etc/dnsmasq.dhcp.hosts&lt;/span&gt;
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;&lt;span style="color:#008000"&gt;# DHCP - DHCP动态分配&lt;/span&gt;
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;&lt;span style="color:#008000"&gt;# [tag:&amp;lt;tag&amp;gt;[,tag:&amp;lt;tag&amp;gt;],][set:&amp;lt;tag&amp;gt;,]&amp;lt;start-addr&amp;gt;[,&amp;lt;end-addr&amp;gt;|&amp;lt;mode&amp;gt;[,&amp;lt;netmask&amp;gt;[,&amp;lt;broadcast&amp;gt;]]][,&amp;lt;lease time&amp;gt;]&lt;/span&gt;
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;dhcp-range=&lt;span style="color:#a31515"&gt;192.168.2.240,192.168.2.254,255.255.255.0,12h&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;/div&gt;
&lt;/div&gt;
&lt;br /&gt;
&lt;div class="highlight-file highlight-file_opened" id="hf-d5aaab98731a55f06c80fc35a8391a77"&gt;
 &lt;div class="highlight-file-header"&gt;
 &lt;a class="fa fa-plus highlight-file-switch" onclick="blog.toggleClassName('hf-d5aaab98731a55f06c80fc35a8391a77','highlight-file_opened')"&gt;/etc/dnsmasq.dhcp.hosts&lt;/a&gt;&lt;a class="fa fa-download highlight-file-download" target="_blank" href="https://linianhui.github.io/computer-networking/dns/dnsmasq.dhcp.hosts" title="下载 /etc/dnsmasq.dhcp.hosts" download&gt;&lt;/a&gt;
 &lt;a class="fa fa-github" target="_blank" href="https://github.com/linianhui/blog/blob/main/src/computer-networking/dns/dnsmasq.dhcp.hosts" title="源码 /etc/dnsmasq.dhcp.hosts"&gt;&lt;/a&gt;&lt;/div&gt;
 &lt;div class="highlight-file-content"&gt;&lt;div class="highlight"&gt;&lt;pre tabindex="0" style="background-color:#fff;-moz-tab-size:4;-o-tab-size:4;tab-size:4;-webkit-text-size-adjust:none;"&gt;&lt;code class="language-ini" data-lang="ini"&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;&lt;span style="color:#008000"&gt;# dhcp-hostsfile=/etc/dnsmasq.dhcp.hosts&lt;/span&gt;
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;&lt;span style="color:#008000"&gt;# https://thekelleys.org.uk/dnsmasq/docs/dnsmasq-man.html&lt;/span&gt;
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;&lt;span style="color:#008000"&gt;# [&amp;lt;hwaddr&amp;gt;][,id:&amp;lt;client_id&amp;gt;|*][,set:&amp;lt;tag&amp;gt;][,tag:&amp;lt;tag&amp;gt;][,&amp;lt;ipaddr&amp;gt;][,&amp;lt;hostname&amp;gt;][,&amp;lt;lease_time&amp;gt;][,ignore]&lt;/span&gt;
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;&lt;span style="color:#008000"&gt;# MAC地址需小写&lt;/span&gt;
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;00:15:5d:02:02:0b,192.168.2.22,deb1.vm.lan&lt;/span&gt;&lt;/span&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;/div&gt;
&lt;/div&gt;
&lt;br /&gt;
&lt;div class="highlight-file highlight-file_opened" id="hf-dd61df059a8e824503d22f5d18fd0352"&gt;
 &lt;div class="highlight-file-header"&gt;
 &lt;a class="fa fa-plus highlight-file-switch" onclick="blog.toggleClassName('hf-dd61df059a8e824503d22f5d18fd0352','highlight-file_opened')"&gt;/etc/dnsmasq.dns.hosts&lt;/a&gt;&lt;a class="fa fa-download highlight-file-download" target="_blank" href="https://linianhui.github.io/computer-networking/dns/dnsmasq.dns.hosts" title="下载 /etc/dnsmasq.dns.hosts" download&gt;&lt;/a&gt;
 &lt;a class="fa fa-github" target="_blank" href="https://github.com/linianhui/blog/blob/main/src/computer-networking/dns/dnsmasq.dns.hosts" title="源码 /etc/dnsmasq.dns.hosts"&gt;&lt;/a&gt;&lt;/div&gt;
 &lt;div class="highlight-file-content"&gt;&lt;div class="highlight"&gt;&lt;pre tabindex="0" style="background-color:#fff;-moz-tab-size:4;-o-tab-size:4;tab-size:4;-webkit-text-size-adjust:none;"&gt;&lt;code class="language-ini" data-lang="ini"&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;&lt;span style="color:#008000"&gt;# addn-hosts=/etc/dnsmasq.dns.hosts&lt;/span&gt;
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;&lt;span style="color:#008000"&gt;# https://thekelleys.org.uk/dnsmasq/docs/dnsmasq-man.html&lt;/span&gt;
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;&lt;span style="color:#008000"&gt;# www.baidu.lan 解析到 192.168.1.2&lt;/span&gt;
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;192.168.2.201 www.baidu.lan&lt;/span&gt;&lt;/span&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;/div&gt;
&lt;/div&gt;
&lt;/p&gt;</description></item></channel></rss>