<?xml version="1.0" encoding="utf-8" standalone="yes"?><rss version="2.0" xmlns:atom="http://www.w3.org/2005/Atom"><channel><title>个税计算器 on Timetombs</title><link>https://linianhui.github.io/tag/%E4%B8%AA%E7%A8%8E%E8%AE%A1%E7%AE%97%E5%99%A8/</link><description>Recent content in 个税计算器 on Timetombs</description><generator>Hugo</generator><language>en</language><lastBuildDate>Sat, 06 Jun 2026 09:14:37 +0800</lastBuildDate><atom:link href="https://linianhui.github.io/tag/%E4%B8%AA%E7%A8%8E%E8%AE%A1%E7%AE%97%E5%99%A8/index.xml" rel="self" type="application/rss+xml"/><item><title>[工具] 个税计算器</title><link>https://linianhui.github.io/tool/tax/</link><pubDate>Tue, 01 Jan 2019 01:01:01 +0800</pubDate><guid>https://linianhui.github.io/tool/tax/</guid><description>&lt;p&gt;&lt;link rel="stylesheet" href="https://s4.zstatic.net/ajax/libs/element-ui/2.15.14/theme-chalk/index.min.css" crossorigin="anonymous" referrerpolicy="no-referrer" /&gt;
&lt;script src="https://s4.zstatic.net/ajax/libs/vue/2.7.16/vue.min.js" crossorigin="anonymous" referrerpolicy="no-referrer"&gt;&lt;/script&gt;
&lt;script src="https://s4.zstatic.net/ajax/libs/element-ui/2.15.14/index.min.js" crossorigin="anonymous" referrerpolicy="no-referrer"&gt;&lt;/script&gt;&lt;br /&gt;
&lt;script src="https://s4.zstatic.net/ajax/libs/echarts/6.0.0/echarts.min.js" crossorigin="anonymous" referrerpolicy="no-referrer"&gt;&lt;/script&gt;&lt;br /&gt;
&lt;style&gt;
 th {
 text-align: right;
 }

 td {
 text-align: right;
 vertical-align: baseline;
 padding: 6px 4px;
 }

 .cell {
 padding: 0 !important;
 }

 .input-fieldset section {
 margin: 6px 0;
 }

 .form-name,
 .form-input {
 position: relative;
 display: inline-block;
 vertical-align: middle;
 }

 .form-name {
 width: 5em;
 text-align: right;
 }

 .form-input {
 margin-left: 1em;
 }

 .el-collapse {
 border: unset;
 }

 .el-collapse-item__wrap,
 .el-collapse-item__header {
 border: unset;
 }

 .el-input-group__prepend {
 padding: 0;
 }

 fieldset {
 border: unset;
 box-shadow: 0 0 2px #ccc;
 max-width: 100%;
 min-width: 100%;
 margin-top: 1em;
 box-sizing: border-box;
 }

 legend {
 background-color: #FFF;
 color: #909399;
 }

 .salary-wrapper {
 overflow-x: auto;
 max-width: 100%;
 }

 .salary-pre {
 font-family: unset;
 font-size: 0;
 margin: 0;
 }

 .salary-table {
 width: 100%;
 margin: 0;
 font-size: 14px;
 }

 .salary-summary sub {
 font-size: 10px;
 padding-left: 2px;
 color: #bbb;
 }

 .row-data {
 color: #666;
 font-family: monospace, Courier, 'Courier New'
 }

 .row-data:hover {
 background-color: #eee;
 cursor: pointer;
 }

 .insurance-table input {
 min-width: 2em;
 max-width: 4em;
 text-align: right;
 }

 .month-detail {
 display: none;
 }

 .month-detail_opened+tr {
 display: table-row;
 }

 .month-detail_opened .month-action-icon::before {
 content: "\e6df";
 }

 .form-input-weight {
 width: 14em !important;
 }
&lt;/style&gt;
&lt;div id="app"&gt;
 &lt;fieldset class="input-fieldset"&gt;
 &lt;legend&gt;参数区域&lt;/legend&gt;
 &lt;section&gt;
 &lt;div class="form-name"&gt;
 &lt;label for="salary"&gt;
 税前月工资
 &lt;/label&gt;
 &lt;/div&gt;
 &lt;div colspan="2" class="form-input"&gt;
 &lt;el-input-number id="salary" v-model="amount" step="1000" :min="0"&gt;
 &lt;/el-input-number&gt;
 &lt;/div&gt;
 &lt;/section&gt;
 &lt;section&gt;
 &lt;div class="form-name"&gt;
 &lt;label for="month"&gt;
 月数
 &lt;/label&gt;
 &lt;/div&gt;
 &lt;div colspan="2" class="form-input"&gt;
 &lt;el-input-number id="month" v-model="month" :min="1" @input="onMonthChange"&gt;&lt;/el-input-number&gt;
 &lt;/div&gt;
 &lt;/section&gt;
 &lt;section&gt;
 &lt;div class="form-name"&gt;
 &lt;label for="insurance"&gt;
 社保基数
 &lt;/label&gt;
 &lt;/div&gt;
 &lt;div class="form-input"&gt;
 &lt;el-collapse&gt;
 &lt;el-collapse-item&gt;
 &lt;template slot="title"&gt;
 &lt;el-select id="insurance" v-model="insuranceName" :popper-append-to-body="false" class="form-input-weight"
 @change="onInsuranceNameChange"&gt;
 &lt;el-option v-for="item in insuranceNameList" :key="item" :label="item" :value="item"&gt;
 &lt;/el-option&gt;
 &lt;/el-select&gt;
 &lt;span&gt;&amp;nbsp;&amp;nbsp;{{insurance.min | CNY}}~{{insurance.max | CNY}}&lt;/span&gt;
 &lt;/template&gt;
 &lt;table class="insurance-table"&gt;
 &lt;tr class="row-header"&gt;
 &lt;th&gt;社保类型&lt;/th&gt;
 &lt;th&gt;最低基数&lt;/th&gt;
 &lt;th&gt;最高基数&lt;/th&gt;
 &lt;th&gt;个人%&lt;/th&gt;
 &lt;th&gt;公司%&lt;/th&gt;
 &lt;/tr&gt;
 &lt;tr&gt;
 &lt;td&gt;&lt;/td&gt;
 &lt;td&gt;&lt;input v-model="insurance.min" @input="onInsuranceMinChange" type="number" min="0"
 placeholder="最低基数"&gt;&lt;/td&gt;
 &lt;td&gt;&lt;input v-model="insurance.max" @input="onInsuranceMaxChange" type="number" min="0"
 placeholder="最高基数"&gt;&lt;/td&gt;
 &lt;td&gt;&lt;/td&gt;
 &lt;td&gt;&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr v-for="item in insurance.items" class="row-data"&gt;
 &lt;td&gt;{{item.name}}&lt;/td&gt;
 &lt;td&gt;&lt;input v-model="item.min" type="number" min="0" placeholder="最低基数"&gt;&lt;/td&gt;
 &lt;td&gt;&lt;input v-model="item.max" type="number" min="0" placeholder="最高基数"&gt;&lt;/td&gt;
 &lt;td&gt;&lt;input v-model="item.personalPercentage" type="number" min="0" max="100" placeholder="个人比例"&gt;&lt;/td&gt;
 &lt;td&gt;&lt;input v-model="item.corporationPercentage" type="number" min="0" max="100" placeholder="公司比例"&gt;&lt;/td&gt;
 &lt;/tr&gt;
 &lt;/table&gt;
 &lt;/el-collapse-item&gt;
 &lt;/el-collapse&gt;
 &lt;/div&gt;
 &lt;/section&gt;
 &lt;section&gt;
 &lt;div class="form-name"&gt;
 &lt;label for="rate"&gt;税率表&lt;/label&gt;
 &lt;/div&gt;
 &lt;div class="form-input"&gt;
 &lt;el-collapse&gt;
 &lt;el-collapse-item&gt;
 &lt;template slot="title"&gt;
 &lt;el-select id="rate" v-model="rateName" :popper-append-to-body="false" class="form-input-weight"&gt;
 &lt;el-option v-for="item in rateNameList" :key="item" :label="item" :value="item"&gt;
 &lt;/el-option&gt;
 &lt;/el-select&gt;
 &lt;span&gt;&amp;nbsp;&amp;nbsp;免征额 {{rate.exempted | CNY}}&lt;/span&gt;
 &lt;/template&gt;
 &lt;table&gt;
 &lt;tr class="row-header"&gt;
 &lt;th&gt;范围&lt;/th&gt;
 &lt;th&gt;税率&lt;/th&gt;
 &lt;th&gt;速算扣除数&lt;/th&gt;
 &lt;/tr&gt;
 &lt;tr v-for="item in rate.items" class="row-data"&gt;
 &lt;td&gt;
 &lt;span&gt;
 {{item.min | CNY}} ~
 &lt;span v-if="item.max"&gt;{{item.max | CNY}}&lt;/span&gt;
 &lt;span v-else&gt;￥∞&lt;/span&gt;
 &lt;/span&gt;
 &lt;/td&gt;
 &lt;td&gt;
 {{item.rate}}%
 &lt;/td&gt;
 &lt;td&gt;
 {{item.quickDeduction | CNY}}
 &lt;/td&gt;
 &lt;/tr&gt;
 &lt;/table&gt;
 &lt;/el-collapse-item&gt;
 &lt;/el-collapse&gt;
 &lt;/div&gt;
 &lt;/section&gt;
 &lt;section&gt;
 &lt;div class="form-name"&gt;
 &lt;label for="bonus"&gt;
 奖金
 &lt;/label&gt;
 &lt;/div&gt;
 &lt;div class="form-input"&gt;
 &lt;el-collapse&gt;
 &lt;el-collapse-item&gt;
 &lt;template slot="title"&gt;
 &lt;span @click.stop&gt;
 &lt;el-input-number id="ebonus" v-model="bonus" step="1000"&gt;&lt;/el-input-number&gt;
 &lt;/span&gt;
 &amp;nbsp;&amp;nbsp;
 &lt;span @click.stop&gt;
 &lt;el-checkbox v-model="bonusSingleTax"&gt;单独计税&lt;/el-checkbox&gt;
 &lt;/span&gt;
 &amp;nbsp;&amp;nbsp; 税率表(月)
 &lt;/template&gt;
 &lt;table&gt;
 &lt;tr class="row-header"&gt;
 &lt;th&gt;范围&lt;/th&gt;
 &lt;th&gt;税率&lt;/th&gt;
 &lt;th&gt;速算扣除数&lt;/th&gt;
 &lt;/tr&gt;
 &lt;tr v-for="item in bonusRates.items" class="row-data"&gt;
 &lt;td&gt;
 &lt;span&gt;
 {{item.min | CNY}} ~
 &lt;span v-if="item.max"&gt;{{item.max | CNY}}&lt;/span&gt;
 &lt;span v-else&gt;￥∞&lt;/span&gt;
 &lt;/span&gt;
 &lt;/td&gt;
 &lt;td&gt;
 {{item.rate}}%
 &lt;/td&gt;
 &lt;td&gt;
 {{item.quickDeduction | CNY}}
 &lt;/td&gt;
 &lt;/tr&gt;
 &lt;/table&gt;
 &lt;/el-collapse-item&gt;
 &lt;/el-collapse&gt;
 &lt;/div&gt;
 &lt;/section&gt;
 &lt;section style="min-height: 47px;"&gt;
 &lt;div class="form-name"&gt;
 &lt;label for="precision"&gt;
 小数位
 &lt;/label&gt;
 &lt;/div&gt;
 &lt;div colspan="2" class="form-input"&gt;
 &lt;el-input-number id="precision" v-model="precision" :min="0" :max="2"
 @change="onPrecisionChange"&gt;&lt;/el-input-number&gt;
 &lt;/div&gt;
 &lt;/section&gt;
 &lt;section&gt;
 &lt;/fieldset&gt;

 &lt;fieldset&gt;
 &lt;legend&gt;结果区域-年合计&lt;/legend&gt;
 &lt;div ref="sumChartDiv" style="width: 100%;height: 300px;"&gt;&lt;/div&gt;
 &lt;/fieldset&gt;

 &lt;fieldset&gt;
 &lt;legend&gt;结果区域-月列表&lt;/legend&gt;
 &lt;div class="salary-wrapper"&gt;
 &lt;pre class="salary-pre"&gt;
 &lt;table class="salary-table"&gt;
 &lt;tr class="row-header"&gt;
 &lt;th style="width: 5em;"&gt;月份&lt;/th&gt;
 &lt;th&gt;税前YTD&lt;/th&gt;
 &lt;th style="width: 6em;"&gt;免征额YTD&lt;/th&gt;
 &lt;th style="width: 7em;"&gt;社保个人YTD&lt;/th&gt;
 &lt;th&gt;税基YTD&lt;/th&gt;
 &lt;th style="width: 3em;"&gt;税率&lt;/th&gt;
 &lt;th&gt;个税&lt;/th&gt;
 &lt;th&gt;个税YTD&lt;/th&gt;
 &lt;th&gt;税后&lt;/th&gt;
 &lt;th&gt;税后YTD&lt;/th&gt;
 &lt;/tr&gt;
 &lt;template v-for="salary in salarys.items"&gt;
 &lt;tr :id="'month-'+salary.month+'-detail'" class="row-data" :onclick="'blog.toggleClassName(\'month-'+salary.month+'-detail\',\'month-detail_opened\')'"&gt;
 &lt;td v-if="salary.bonus &gt; 0"&gt;奖金 &lt;i class="el-icon-arrow-right month-action-icon"&gt;&lt;/i&gt;&lt;/td&gt;
 &lt;td v-else &gt;{{salary.month}}月 &lt;i class="el-icon-arrow-right month-action-icon"&gt;&lt;/i&gt;&lt;/td&gt;
 &lt;td&gt;{{salary.baseYTD | CNY}}&lt;/td&gt;
 &lt;td&gt;{{salary.exemptedYTD | CNY}}&lt;/td&gt;
 &lt;td&gt;{{salary.insurances.personalYTD | CNY}}&lt;/td&gt;
 &lt;td&gt;{{salary.taxableYTD | CNY}}&lt;/td&gt;
 &lt;td&gt;{{salary.rate.rate}}%&lt;/td&gt;
 &lt;td&gt;{{salary.tax | CNY}}&lt;/td&gt;
 &lt;td&gt;{{salary.taxYTD | CNY}}&lt;/td&gt;
 &lt;td&gt;{{salary.actual | CNY}}&lt;/td&gt;
 &lt;td&gt;{{salary.actualYTD | CNY}}&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr class="month-detail"&gt;
 &lt;td style="padding: 0; font-size: 0;"&gt; &lt;/td&gt;
 &lt;td colspan="10" style="padding: 0; font-size: 0;"&gt;
 &lt;table style="padding: 0;margin: 0; font-size: 14px;width: 100%;border-width: 0;background-color: #efe;"&gt;
 &lt;tr&gt;
 &lt;td v-if="salary.bonus &gt; 0" colspan="3"&gt;奖金&lt;/td&gt;
 &lt;td colspan="3" v-else &gt;{{salary.month}}月&lt;/td&gt;
 &lt;td&gt;社保基数&lt;/td&gt;
 &lt;td&gt;税率/费率&lt;/td&gt;
 &lt;td&gt;本月&lt;/td&gt;
 &lt;td&gt;YTD(年累计)&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr class="row-data"&gt;
 &lt;td rowspan="12"&gt;个人&lt;/td&gt;
 &lt;td&gt;税前&lt;/td&gt;
 &lt;td colspan="3"&gt;&lt;/td&gt;
 &lt;td&gt;{{salary.base | CNY}}&lt;/td&gt;
 &lt;td&gt;{{salary.baseYTD | CNY}}&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr class="row-data"&gt;
 &lt;td rowspan="7"&gt;社保&lt;/td&gt;
 &lt;td&gt;合计&lt;/td&gt;
 &lt;td colspan="2"&gt;&lt;/td&gt;
 &lt;td&gt;{{salary.insurances.personal | CNY}}&lt;/td&gt;
 &lt;td&gt;{{salary.insurances.personalYTD | CNY}}&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr v-for="insurance in salary.insurances.items" class="row-data"&gt;
 &lt;td&gt;{{insurance.name}}&lt;/td&gt;
 &lt;td&gt;{{insurance.base}}&lt;/td&gt;
 &lt;td&gt;{{insurance.personalPercentage}}%&lt;/td&gt;
 &lt;td&gt;{{insurance.personal | CNY}}&lt;/td&gt;
 &lt;td&gt;{{insurance.personalYTD | CNY}}&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr class="row-data"&gt;
 &lt;td rowspan="3"&gt;个税&lt;/td&gt;
 &lt;td&gt;应纳税所得额&lt;/td&gt;
 &lt;td&gt;&lt;/td&gt;
 &lt;td&gt;{{salary.rate.rate | CNY}}%&lt;/td&gt;
 &lt;td&gt;{{salary.taxable | CNY}}&lt;/td&gt;
 &lt;td&gt;{{salary.taxableYTD | CNY}}&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr class="row-data"&gt;
 &lt;td&gt;免征额&lt;/td&gt;
 &lt;td colspan="2"&gt;&lt;/td&gt;
 &lt;td&gt;{{salary.exempted | CNY}}&lt;/td&gt;
 &lt;td&gt;{{salary.exemptedYTD | CNY}}&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr class="row-data"&gt;
 &lt;td &gt;应纳税&lt;/td&gt;
 &lt;td colspan="2"&gt;&lt;/td&gt;
 &lt;td&gt;{{salary.tax | CNY}}&lt;/td&gt;
 &lt;td&gt;{{salary.taxYTD | CNY}}&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr class="row-data"&gt;
 &lt;td&gt;税后&lt;/td&gt;
 &lt;td colspan="3"&gt;&lt;/td&gt;
 &lt;td&gt;{{salary.actual | CNY}}&lt;/td&gt;
 &lt;td&gt;{{salary.actualYTD | CNY}}&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr class="row-data"&gt;
 &lt;td rowspan="8"&gt;公司&lt;/td&gt;
 &lt;td&gt;支出&lt;/td&gt;
 &lt;td colspan="3"&gt;&lt;/td&gt;
 &lt;td&gt;{{salary.corporation | CNY}}&lt;/td&gt;
 &lt;td&gt;{{salary.corporationYTD | CNY}}&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr class="row-data"&gt;
 &lt;td rowspan="7"&gt;社保&lt;/td&gt;
 &lt;td&gt;合计&lt;/td&gt;
 &lt;td colspan="2"&gt;&lt;/td&gt;
 &lt;td&gt;{{salary.insurances.corporation | CNY}}&lt;/td&gt;
 &lt;td&gt;{{salary.insurances.corporationYTD | CNY}}&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr v-for="insurance in salary.insurances.items" class="row-data"&gt;
 &lt;td&gt;{{insurance.name}}&lt;/td&gt;
 &lt;td&gt;{{insurance.base}}&lt;/td&gt;
 &lt;td&gt;{{insurance.corporationPercentage}}%&lt;/td&gt;
 &lt;td&gt;{{insurance.corporation | CNY}}&lt;/td&gt;
 &lt;td&gt;{{insurance.corporationYTD | CNY}}&lt;/td&gt;
 &lt;/tr&gt;
 &lt;/table&gt;
 &lt;/td&gt;
 &lt;/tr&gt;
 &lt;/template&gt;
 &lt;/table&gt;
 &lt;/pre&gt;
 &lt;/div&gt;
 &lt;/fieldset&gt;
&lt;/div&gt;
&lt;script src="rates.js"&gt;&lt;/script&gt;
&lt;script src="insurances.js"&gt;&lt;/script&gt;
&lt;script src="calculator.js"&gt;&lt;/script&gt;
&lt;script src="chart.js"&gt;&lt;/script&gt;
&lt;script src="app.js"&gt;&lt;/script&gt;&lt;/p&gt;</description></item></channel></rss>