			&lt;/tr&gt;
			&lt;tr&gt;
					&lt;td&gt;-V&lt;/td&gt;
					&lt;td&gt;--version&lt;/td&gt;
			&lt;/tr&gt;
			&lt;tr&gt;
					&lt;td&gt;-a&lt;/td&gt;
					&lt;td&gt;--all&lt;/td&gt;
			&lt;/tr&gt;
			&lt;tr&gt;
					&lt;td&gt;-n&lt;/td&gt;
					&lt;td&gt;--numeric&lt;/td&gt;
			&lt;/tr&gt;
			&lt;tr&gt;
					&lt;td&gt;-t&lt;/td&gt;
					&lt;td&gt;--tcp&lt;/td&gt;
			&lt;/tr&gt;
			&lt;tr&gt;
					&lt;td&gt;-u&lt;/td&gt;
					&lt;td&gt;--udp&lt;/td&gt;
			&lt;/tr&gt;
			&lt;tr&gt;
