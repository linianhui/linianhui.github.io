&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;echo &lt;span style="color:#a31515"&gt;&amp;#34;&lt;/span&gt;&lt;span style="color:#a31515"&gt;${&lt;/span&gt;CLIENT_JSON_TEMPLATE&lt;span style="color:#a31515"&gt;}&lt;/span&gt;&lt;span style="color:#a31515"&gt;&amp;#34;&lt;/span&gt; | envsubst &amp;gt; v2ray-client-config.json
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;
