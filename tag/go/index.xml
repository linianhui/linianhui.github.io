&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;&lt;span style="color:#a31515"&gt; &amp;#34;encryption&amp;#34;: &amp;#34;none&amp;#34;
