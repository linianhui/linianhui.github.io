&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;&lt;span style="color:#a31515"&gt; | `-._ `._ / _.-&amp;#39;&lt;/span&gt; | PID: 5177
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt; &lt;span style="color:#a31515"&gt;`&lt;/span&gt;-._ &lt;span style="color:#a31515"&gt;`&lt;/span&gt;-._ &lt;span style="color:#a31515"&gt;`&lt;/span&gt;-./ _.-&lt;span style="color:#a31515"&gt;&amp;#39; _.-&amp;#39;&lt;/span&gt; 
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt; |&lt;span style="color:#a31515"&gt;`&lt;/span&gt;-._&lt;span style="color:#a31515"&gt;`&lt;/span&gt;-._ &lt;span style="color:#a31515"&gt;`&lt;/span&gt;-.__.-&lt;span style="color:#a31515"&gt;&amp;#39; _.-&amp;#39;&lt;/span&gt;_.-&lt;span style="color:#a31515"&gt;&amp;#39;| 
&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;&lt;span style="color:#a31515"&gt; | `-._`-._ _.-&amp;#39;&lt;/span&gt;_.-&lt;span style="color:#a31515"&gt;&amp;#39; | http://redis.io 
&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;&lt;span style="color:#a31515"&gt; `-._ `-._`-.__.-&amp;#39;&lt;/span&gt;_.-&lt;span style="color:#a31515"&gt;&amp;#39; _.-&amp;#39;&lt;/span&gt; 
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt; |&lt;span style="color:#a31515"&gt;`&lt;/span&gt;-._&lt;span style="color:#a31515"&gt;`&lt;/span&gt;-._ &lt;span style="color:#a31515"&gt;`&lt;/span&gt;-.__.-&lt;span style="color:#a31515"&gt;&amp;#39; _.-&amp;#39;&lt;/span&gt;_.-&lt;span style="color:#a31515"&gt;&amp;#39;| 
