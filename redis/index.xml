&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;5177:M 19 Mar 2021 04:08:38.091 * monotonic clock: POSIX clock_gettime
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt; _._ 
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt; _.-&lt;span style="color:#a31515"&gt;``&lt;/span&gt;__ &lt;span style="color:#a31515"&gt;&amp;#39;&amp;#39;&lt;/span&gt;-._ 
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt; _.-&lt;span style="color:#a31515"&gt;``&lt;/span&gt; &lt;span style="color:#a31515"&gt;`&lt;/span&gt;. &lt;span style="color:#a31515"&gt;`&lt;/span&gt;_. &lt;span style="color:#a31515"&gt;&amp;#39;&amp;#39;&lt;/span&gt;-._ Redis 6.2.1 (00000000/0) 64 bit
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt; .-&lt;span style="color:#a31515"&gt;``&lt;/span&gt; .-&lt;span style="color:#a31515"&gt;```&lt;/span&gt;. &lt;span style="color:#a31515"&gt;```&lt;/span&gt;&lt;span style="color:#a31515"&gt;\/&lt;/span&gt; _.,_ &lt;span style="color:#a31515"&gt;&amp;#39;&amp;#39;&lt;/span&gt;-._ 
